# =============================================================================
# VERIHOME - CONFIGURACION DE ENTORNO DE PRODUCCION
# =============================================================================
# Copiar este archivo a .env.prod y completar con valores reales
# NUNCA commitear .env.prod al repositorio

# =============================================================================
# DJANGO
# =============================================================================
SECRET_KEY=CAMBIAR_POR_CLAVE_SEGURA_DE_50_CARACTERES_MINIMO
DEBUG=False
ALLOWED_HOSTS=verihome.com,www.verihome.com,app.verihome.com

# =============================================================================
# BASE DE DATOS (PostgreSQL)
# =============================================================================
DATABASE_ENGINE=postgresql
DATABASE_NAME=verihome_prod
DATABASE_USER=verihome_user
DATABASE_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_CONN_MAX_AGE=600

# =============================================================================
# REDIS (Cache y Celery)
# =============================================================================
REDIS_URL=redis://:CAMBIAR_REDIS_PASSWORD@redis:6379/1
REDIS_PASSWORD=CAMBIAR_REDIS_PASSWORD
CELERY_BROKER_URL=redis://:CAMBIAR_REDIS_PASSWORD@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CAMBIAR_REDIS_PASSWORD@redis:6379/0

# =============================================================================
# EMAIL (SMTP)
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=CAMBIAR_EMAIL@gmail.com
EMAIL_HOST_PASSWORD=CAMBIAR_APP_PASSWORD
DEFAULT_FROM_EMAIL=VeriHome <CAMBIAR_EMAIL@gmail.com>
SERVER_EMAIL=VeriHome <CAMBIAR_EMAIL@gmail.com>

# =============================================================================
# CORS
# =============================================================================
CORS_ALLOWED_ORIGINS=https://verihome.com,https://www.verihome.com,https://app.verihome.com

# =============================================================================
# MAPBOX
# =============================================================================
MAPBOX_ACCESS_TOKEN=CAMBIAR_POR_TOKEN_MAPBOX

# =============================================================================
# PAGOS (Stripe)
# =============================================================================
STRIPE_PUBLISHABLE_KEY=pk_live_CAMBIAR
STRIPE_SECRET_KEY=sk_live_CAMBIAR
STRIPE_WEBHOOK_SECRET=whsec_CAMBIAR

# =============================================================================
# PAGOS (Wompi - Colombia)
# =============================================================================
WOMPI_PUBLIC_KEY=CAMBIAR
WOMPI_PRIVATE_KEY=CAMBIAR
WOMPI_SANDBOX_MODE=False

# =============================================================================
# SEGURIDAD
# =============================================================================
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# =============================================================================
# MONITORING (Sentry)
# =============================================================================
SENTRY_DSN=CAMBIAR_POR_DSN_DE_SENTRY

# =============================================================================
# FRONTEND
# =============================================================================
FRONTEND_URL=https://app.verihome.com

# =============================================================================
# SUPERUSUARIO (solo primer deploy)
# =============================================================================
DJANGO_SUPERUSER_EMAIL=admin@verihome.com
DJANGO_SUPERUSER_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# =============================================================================
# PGADMIN (opcional)
# =============================================================================
PGADMIN_EMAIL=admin@verihome.com
PGLADMIN_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# =============================================================================
# BIOMETRIC PROVIDERS (ver contracts/biometric_providers/)
# =============================================================================
# Valores válidos: demo | truora (truora se enchufa en TR-3).
# Truora Identity cubre face liveness con head movements + OCR cédula
# CO + cruce Registraduría en un único proceso. Hasta TR-3 demo sigue
# siendo el default y los endpoints emiten disclosure Ley 1581/2012.
BIOMETRIC_FACIAL_PROVIDER=demo
BIOMETRIC_MIN_FACE_QUALITY=0.7
BIOMETRIC_MIN_FACE_SIMILARITY=0.85

# OCR documento de identidad. Mismo plan que el facial.
BIOMETRIC_DOCUMENT_PROVIDER=demo

# --- Truora Identity (TR-3 · placeholder hasta tener cuenta) ---
# JWT v1 generado en https://app.truora.com/ → API Keys → Create.
# NUNCA commitear el valor real; se inyecta vía .env local o secrets.
TRUORA_API_KEY=
# Account ID visible en https://app.truora.com/ → Profile.
TRUORA_ACCOUNT_ID=
# Secret para verificar HMAC del webhook (lo entrega Truora al
# configurar la URL de callback en la dashboard).
TRUORA_WEBHOOK_SECRET=
# Base URL del API (default productivo Truora).
TRUORA_BASE_URL=https://api.identity.truora.com

# --- Análisis de voz ---
# Valor válido hoy: demo. P0.3b integrará un provider real
# (Google Speech-to-Text / Azure Speech). El andamio VoiceProvider ya
# está integrado; el provider real se enganchará como drop-in sin
# tocar el service.
BIOMETRIC_VOICE_PROVIDER=demo

# NOTA LEGAL (Ley 1581/2012): Truora procesa datos en Colombia (servidor
# en CO) — no requiere TDI. El provider de voz futuro sí podría requerir
# addendum si procesa fuera del país.
