# Configuración de Mapbox para VeriHome Colombia
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Configuración geográfica para Colombia
VITE_DEFAULT_COUNTRY=CO
VITE_DEFAULT_LAT=4.5709
VITE_DEFAULT_LNG=-74.2973
VITE_DEFAULT_ZOOM=6

# API Configuration
VITE_API_URL=http://localhost:8000/api/v1

# Payment Gateway Configuration
# Stripe - Get your test key from https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# PayPal - Get your sandbox client ID from https://developer.paypal.com/dashboard/
VITE_PAYPAL_CLIENT_ID=sb_your_paypal_client_id_here

# Sentry Error Monitoring (optional - app works without it)
VITE_SENTRY_DSN=
VITE_APP_VERSION=1.0.0
